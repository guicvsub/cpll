<Page x:Class="cpllv2.Views.MainWindow"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F5F7FA"
      Title="MainWindow">

    <Grid>
        <Border Background="White"
                CornerRadius="15"
                Padding="30"
                Width="400"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                >

            <StackPanel>

                <!-- Título -->
                <TextBlock Text="Cadastro de Alunos"
                           FontSize="22"
                           FontWeight="Bold"
                           Margin="0 0 0 20"
                           HorizontalAlignment="Center"/>

                <!-- Nome -->
                <TextBlock Text="Nome"/>
                <TextBox x:Name="TxtNome"
                         Height="35"
                         Margin="0 5 0 15"
                         Padding="5"/>

                <!-- Email -->
                <TextBlock Text="Email"/>
                <TextBox x:Name="TxtEmail"
                         Height="35"
                         Margin="0 5 0 15"
                         Padding="5"/>

                <!-- Idade -->
                <TextBlock Text="Idade"/>
                <TextBox x:Name="TxtIdade"
                         Height="35"
                         Margin="0 5 0 20"
                         Padding="5"/>

                <!-- Botões -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">

                    <Button Content="Inserir"
                            Width="120"
                            Height="40"
                            Margin="5"
                            Background="#4CAF50"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="BtnInserir_Click"/>

                    <Button Content="Listar"
                            Width="120"
                            Height="40"
                            Margin="5"
                            Background="#2196F3"
                            Foreground="White"
                            FontWeight="Bold"
                            Click="BtnListar_Click"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Page>
